{% extends 'base.html.twig' %}

{% block title %}HIKI - Login{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('styles/css/pages/auth.css') }}">
{% endblock %}

{% block body %}
    <div class="auth-wrap">
        <div class="auth-card">
            <p class="login-title">Welcome Back</p>
            <p class="login-sub">Sign in to your account</p>

            {% if error %}
                <p class="error">{{ error.messageKey|trans(error.messageData, 'security') }}</p>
            {% endif %}

            <form class="auth-form" action="{{ path('app_login') }}" method="POST">
                <div class="input-box">
                    <input type="email" id="email" name="email" placeholder=" "
                           value="{{ last_username }}" required autocomplete="email">
                    <label for="email">Email</label>
                </div>
                <div class="input-box">
                    <input type="password" id="password" name="password" placeholder=" " required autocomplete="current-password">
                    <label for="password">Password</label>
                </div>
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                <button class="btn-login" type="submit">Sign in</button>
            </form>

            <div class="signup-row">
                Don't have an account? <a href="{{ path('app_register') }}">Sign up</a>
            </div>
        </div>
    </div>
{% endblock %}
