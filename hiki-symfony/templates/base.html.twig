<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}HIKI{% endblock %}</title>
    <link rel="icon" href="{{ asset('images/hiki-mark.svg') }}">
    <style>
        #starCanvas {
            position: fixed;
            inset: 0;
            z-index: 0;
            pointer-events: none;
        }
    </style>
    {% block stylesheets %}{% endblock %}
    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>
<body>
    <canvas id="starCanvas" aria-hidden="true"></canvas>

    {% include '_nav.html.twig' %}

    <div class="page-shell">
        {% block body %}{% endblock %}
    </div>

    {% include '_toggle.html.twig' %}
</body>
</html>
